---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const stripMarkdown = (content: string): string =>
  content
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
    .replace(/\[([^\]]*)\]\([^)]*\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/(^|\s)[#>*_~\-]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const createExcerpt = (content: string, maxLength = 180): string => {
  const plainText = stripMarkdown(content);
  if (plainText.length <= maxLength) {
    return plainText;
  }

  const clipped = plainText.slice(0, maxLength);
  const lastSpace = clipped.lastIndexOf(" ");
  return `${(lastSpace > 0 ? clipped.slice(0, lastSpace) : clipped).trim()}...`;
};

const postsWithPreview = posts.map((post) => {
  const body = typeof post.body === "string" ? post.body : "";
  return {
    ...post,
    excerpt: createExcerpt(body),
  };
});

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="max-w-5xl mx-auto px-4 py-12">
      <section>
        <h1 class="text-4xl md:text-5xl font-bold text-ink mb-8 text-center">All Posts</h1>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 list-none p-0 m-0">
          {
            postsWithPreview.map((post, idx) => (
              <li class:list={[idx === 0 ? "md:col-span-2 text-center" : ""]}>
                <a
                  href={`${base}blog/${post.id}/`}
                  class="block p-5 rounded-lg no-underline transition-colors hover:bg-muted-light/60 group"
                >
                  <h4
                    class:list={[
                      "m-0 font-bold text-ink leading-tight group-hover:text-ale-amber transition-colors",
                      idx === 0 ? "text-3xl md:text-4xl" : "text-xl",
                    ]}
                  >
                    {post.data.title}
                  </h4>
                  <p class="text-sm text-muted my-1.5">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                  <p class="text-muted-dark line-clamp-2 m-0">{post.data.description}</p>
                  <p class="text-sm text-muted-dark/80 line-clamp-3 mt-2 mb-0">{post.excerpt}</p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
