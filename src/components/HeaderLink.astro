---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(base, '').replace(/^\//, '');
const subpath = pathname.match(/[^\/]+/);
const target = (href as string).replace(/^\//, '');
const isActive = target === pathname || target === subpath?.[0];
---

<a
  href={href}
  class:list={[
    'inline-block py-3 px-2 text-ink no-underline border-b-4 border-transparent transition-colors hover:text-ale-amber',
    { 'border-ale-amber font-bold': isActive },
    className,
  ]}
  {...props}
>
  <slot />
</a>
