---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const stripMarkdown = (content: string): string =>
  content
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
    .replace(/\[([^\]]*)\]\([^)]*\)/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/(^|\s)[#>*_~\-]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const createExcerpt = (content: string, maxLength = 180): string => {
  const plainText = stripMarkdown(content);
  if (plainText.length <= maxLength) {
    return plainText;
  }

  const clipped = plainText.slice(0, maxLength);
  const lastSpace = clipped.lastIndexOf(" ");
  return `${(lastSpace > 0 ? clipped.slice(0, lastSpace) : clipped).trim()}...`;
};

const postsWithPreview = posts.map((post) => {
  const body = typeof post.body === "string" ? post.body : "";
  return {
    ...post,
    excerpt: createExcerpt(body),
  };
});

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      main {
        width: 960px;
      }
      ul {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      ul li {
        width: calc(50% - 1rem);
      }
      ul li * {
        text-decoration: none;
        transition: 0.2s ease;
      }
      ul li:first-child {
        width: 100%;
        margin-bottom: 1rem;
        text-align: center;
      }
      ul li:first-child .title {
        font-size: 2.369rem;
      }
      ul li a {
        display: block;
      }
      .title {
        margin: 0;
        color: rgb(var(--black));
        line-height: 1;
      }
      .date {
        margin: 0;
        color: rgb(var(--gray));
      }
      .preview-description,
      .preview-excerpt {
        margin: 0.5rem 0 0;
        color: rgb(var(--gray-dark));
        line-height: 1.45;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .preview-description {
        -webkit-line-clamp: 2;
      }
      .preview-excerpt {
        -webkit-line-clamp: 3;
      }
      ul li a:hover .title {
        color: var(--accent);
      }
      ul a:hover img {
        box-shadow: var(--box-shadow);
      }
      @media (max-width: 720px) {
        ul {
          gap: 0.5em;
        }
        ul li {
          width: 100%;
          text-align: center;
        }
        ul li:first-child {
          margin-bottom: 0;
        }
        ul li:first-child .title {
          font-size: 1.563em;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section>
        <h1>All Posts</h1>
        <ul>
          {
            postsWithPreview.map((post) => (
              <li>
                <a href={`${base}blog/${post.id}/`}>
                  <h4 class="title">{post.data.title}</h4>
                  <p class="date">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                  <p class="preview-description">{post.data.description}</p>
                  <p class="preview-excerpt">{post.excerpt}</p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
