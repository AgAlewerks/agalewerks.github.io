---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = posts.slice(0, 5);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="max-w-3xl mx-auto px-4 py-12">
      <section class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-ink mb-3">Welcome to Ag Alewerks</h1>
        <p class="text-lg text-muted-dark">
          Hand crafted ales by Silvia &amp; Barry — a homebrewing chronicle of recipes,
          contests, and lessons learned from the kettle.
        </p>
        <p class="mt-4">
          <a href={`${base}blog/`} class="text-ale-amber hover:text-ale-dark font-semibold">Read all posts &rarr;</a>
          <span class="mx-2 text-muted">·</span>
          <a href={`${base}our-beers/`} class="text-ale-amber hover:text-ale-dark font-semibold">See our beers</a>
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-ink mb-6">Recent posts</h2>
        <ul class="list-none p-0 m-0 space-y-4">
          {
            recent.map((post) => (
              <li>
                <a
                  href={`${base}blog/${post.id}/`}
                  class="block p-4 rounded-lg no-underline text-inherit transition-colors hover:bg-muted-light/60"
                >
                  <h3 class="m-0 text-xl font-bold text-ale-dark hover:text-ale-amber">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-muted my-1">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                  <p class="m-0 text-muted-dark">{post.data.description}</p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
