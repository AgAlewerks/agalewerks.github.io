---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = posts.slice(0, 5);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="intro">
        <h1>Welcome to Ag Alewerks</h1>
        <p>
          Hand crafted ales by Silvia &amp; Barry — a homebrewing chronicle of recipes,
          contests, and lessons learned from the kettle.
        </p>
        <p>
          <a href={`${base}blog/`}>Read all posts &rarr;</a>
          &nbsp;·&nbsp;
          <a href={`${base}our-beers/`}>See our beers</a>
        </p>
      </section>

      <section class="recent">
        <h2>Recent posts</h2>
        <ul>
          {
            recent.map((post) => (
              <li>
                <a href={`${base}blog/${post.id}/`}>
                  <h3>{post.data.title}</h3>
                  <p class="date"><FormattedDate date={post.data.pubDate} /></p>
                  <p>{post.data.description}</p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 720px;
    max-width: calc(100% - 2em);
  }
  .intro {
    margin-bottom: 3em;
    text-align: center;
  }
  .intro h1 {
    font-size: 2.5em;
    margin-bottom: 0.5em;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  li {
    margin-bottom: 2em;
  }
  li a {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1em;
    border-radius: 8px;
    transition: background 0.2s;
  }
  li a:hover {
    background: rgba(var(--gray-light), 0.6);
  }
  li h3 {
    margin: 0 0 0.25em;
    color: var(--accent-dark);
  }
  li .date {
    color: rgb(var(--gray));
    font-size: 0.9em;
    margin-bottom: 0.5em;
  }
  li p {
    margin: 0;
  }
</style>
